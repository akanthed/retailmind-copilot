# RetailMind AI - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# AWS API Gateway URL
# Get this from: AWS Console → API Gateway → RetailMind-API → Stages → dev
VITE_API_URL=https://YOUR_API_GATEWAY_ID.execute-api.us-east-1.amazonaws.com/dev

# SerpAPI Key (for real e-commerce price comparison)
# Get a free key at: https://serpapi.com (100 searches/month free)
# Without this key, the system will use synthetic/simulated prices
SERPAPI_KEY=3989baebf02c8acc70c537337430670433041a985b0df6f56f5e04bb5e1c533e

# Optional: Add other environment variables as needed
# VITE_AWS_REGION=us-east-1
# VITE_ENABLE_ANALYTICS=false
