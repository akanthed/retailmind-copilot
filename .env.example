# RetailMind AI - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# AWS API Gateway URL
# Get this from: AWS Console → API Gateway → RetailMind-API → Stages → dev
VITE_API_URL=https://YOUR_API_GATEWAY_ID.execute-api.us-east-1.amazonaws.com/dev

# SerpAPI Key (for real e-commerce price comparison)
# Get a free key at: https://serpapi.com (100 searches/month free)
# Without this key, the system will use synthetic/simulated prices
# SERPAPI_KEY=YOUR_API_KEY

# AWS Cognito Authentication (required for user login/signup)
# Get these values by running: ./backend/setup-cognito.ps1
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Add other environment variables as needed
# VITE_ENABLE_ANALYTICS=false

# Backend Lambda environment variables (set in AWS Lambda console / scripts)
# These should be configured in Lambda function environment variables, not here
# SERPAPI_KEY=YOUR_API_KEY
# BEDROCK_QUERY_MODEL=us.amazon.nova-micro-v1:0
# ENABLE_AI_RERANKING=true
# ENABLE_STRICT_FILTERING=true
# METRIC_NAMESPACE=RetailMind

# Available Amazon Bedrock Models for Query Expansion & Re-ranking:
# - us.amazon.nova-micro-v1:0 (Recommended - Fast, cost-effective)
# - us.amazon.nova-lite-v1:0 (Better quality, slightly slower)
# - us.amazon.nova-pro-v1:0 (Best quality, higher cost)
# - anthropic.claude-3-haiku-20240307-v1:0 (Alternative option)
